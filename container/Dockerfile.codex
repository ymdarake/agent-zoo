# Codex CLI agent image
# B-1: 共通 base （agent-zoo-base:latest）に Codex CLI と run-codex.sh を載せる。

FROM agent-zoo-base:latest

ARG HOST_UID=1001

RUN npm install -g @openai/codex

COPY run-codex.sh /usr/local/bin/run-codex.sh
RUN chmod +x /usr/local/bin/run-codex.sh

RUN useradd -m -u ${HOST_UID} codex
RUN mkdir -p /home/codex/.codex && chown -R codex:codex /home/codex/.codex
USER codex
