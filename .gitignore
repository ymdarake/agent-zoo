# Environment
.env*
.venv/

# Runtime policy (dashboard writes here, base policy.toml is preserved)
*.runtime.toml

# Data (runtime generated)
data/*.db
data/*.db-wal
data/*.db-shm
workspace/

# Certificates (runtime generated, may contain private keys)
certs/*
!certs/.gitkeep

# Python (addons/__pycache__がproxyコンテナに影響するため確実に除外)
__pycache__/
*.pyc
.pytest_cache/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

