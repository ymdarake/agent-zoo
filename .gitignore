# Environment
.env*
.venv/

# Runtime policy (dashboard writes here, base policy.toml is preserved)
*.runtime.toml

# Data / certs / runtime artifacts (ADR 0002 では bundle/ 配下、互換のため root data/ もカバー)
data/*.db
data/*.db-wal
data/*.db-shm
bundle/data/*.db
bundle/data/*.db-wal
bundle/data/*.db-shm
bundle/certs/*
!bundle/certs/.gitkeep
!bundle/certs/extra
bundle/certs/extra/*
!bundle/certs/extra/.gitkeep
certs/*
!certs/.gitkeep

# zoo init で生成された user workspace の .zoo/ が誤って source repo に置かれた場合
.zoo/

# Python
__pycache__/
*.pyc
.pytest_cache/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
