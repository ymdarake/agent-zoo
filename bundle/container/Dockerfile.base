# 共通 base イメージ（agent-zoo-base:latest）
# B-1: claude / codex / gemini で共有する OS layer
# B-2: 開発用 CLI ツール群（python3/jq/less/ripgrep）を同梱
# D-1: 企業 proxy 配下での apt 失敗回避のため extra CA を取り込む
# UID 固定は agent ごとの Dockerfile（claude/codex/...）で行う。
#
# NOTE: 本イメージは **ローカル daemon に `agent-zoo-base:latest` として保存** される
#   （registry には push しない、local-only build 方針）。
#   各 agent の Dockerfile は `FROM agent-zoo-base:latest` で参照するため、
#   `make build` / `zoo build` を使うこと（依存解決込みで base を先にビルドする）。
#   直接 `docker build` する場合は事前に `make build-base` 必須。

FROM node:20-slim

# Extra CA certificates (D-1): host の certs/extra/ にユーザーが置いた CA を取り込む
# build context = repo root を想定。空ディレクトリでも error にならないよう .gitkeep を許容
COPY certs/extra/ /usr/local/share/ca-certificates/extra/
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    git sqlite3 curl wget gnupg \
    python3 python3-pip jq less ripgrep \
    && rm -rf /var/lib/apt/lists/*

# B-2 (cont.): GitHub CLI (gh) を公式 apt repo から install (#19)
RUN mkdir -p -m 755 /etc/apt/keyrings \
    && wget -nv -O- https://cli.github.com/packages/githubcli-archive-keyring.gpg | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# B-2 (cont.): GitLab CLI (glab) を release ページから .deb 直 install
# 更新時は GLAB_VERSION を書き換え、make build-base
ARG GLAB_VERSION=1.92.1
RUN ARCH=$(dpkg --print-architecture) \
    && curl -sSL "https://gitlab.com/gitlab-org/cli/-/releases/v${GLAB_VERSION}/downloads/glab_${GLAB_VERSION}_linux_${ARCH}.deb" -o /tmp/glab.deb \
    && dpkg -i /tmp/glab.deb \
    && rm /tmp/glab.deb

COPY container/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /workspace
