FROM node:20-slim

# ホスト側のUIDと合わせてworkspaceのパーミッション問題を防止
ARG HOST_UID=1001

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git sqlite3 curl \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY run-codex.sh /usr/local/bin/run-codex.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/run-codex.sh

WORKDIR /workspace
RUN useradd -m -u ${HOST_UID} codex
# 認証データ保存先を事前作成（ボリュームマウント時の所有権問題を防止）
RUN mkdir -p /home/codex/.codex \
    && chown -R codex:codex /home/codex/.codex
USER codex
